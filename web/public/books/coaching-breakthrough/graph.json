  "nodes": [
    {
      "id": "全书导读",
      "type": "topic",
      "tagline": "这本书要解决的不是怎样把教练做得更流畅，而是如何在对话中创造真正的“顿悟时刻”：教练先调到深度临在，再帮助客户从旧叙事中产生新认知，并把洞见转成承诺。"
    },
    {
      "id": "全书脉络",
      "type": "topic",
      "tagline": "按章节推进链快速拿到这本书的主线。"
    },
    {
      "id": "核心内容总览",
      "type": "topic",
      "tagline": "把主题、概念、方法和章节资产收成一张总表。"
    },
    {
      "id": "单章目录",
      "type": "topic",
      "tagline": "从章节切进去，顺着原书推进。"
    },
    {
      "id": "选题角度",
      "type": "topic",
      "tagline": "把书里的结构问题翻译成可直接做内容的切口。"
    },
    {
      "id": "视觉表达钩子",
      "type": "topic",
      "tagline": "提炼适合信息图、九图和封面表达的视觉对象。"
    },
    {
      "id": "教练的突破",
      "type": "topic",
      "tagline": "这本书要解决的不是怎样把教练做得更流畅，而是如何在对话中创造真正的“顿悟时刻”：教练先调到深度临在，再帮助客户从旧叙事中产生新认知，并把洞见转成承诺。"
    },
    {
      "id": "价值观没对齐，再好的计划也执行不久",
      "type": "topic",
      "tagline": "读者容易把「行动方案看着合理，身体却完全不想动。」当成表面问题，但这本书真正要处理的是「价值观契合」与「洞见转承诺」之间的结构关系。"
    },
    {
      "id": "分与第五部分：调试操作系统，把洞见变成承诺：这一段到底在解决什么问题",
      "type": "topic",
      "tagline": "表面看是「操作系统、社交需求和价值观会决定人如何解释世界。」，但这一段真正想带读者回到「分与第五部分：调试操作系统，把洞见变成承诺」中的「操作系统」。"
    },
    {
      "id": "分：他们真正渴望的成果是什么：这一段到底在解决什么问题",
      "type": "topic",
      "tagline": "表面看是「目标不清，再好的提问也会发散。」，但这一段真正想带读者回到「分：他们真正渴望的成果是什么」中的「去自我化」。"
    },
    {
      "id": "分：保持以客户为中心：这一段到底在解决什么问题",
      "type": "topic",
      "tagline": "表面看是「情绪变化是机会，不是麻烦。」，但这一段真正想带读者回到「分：保持以客户为中心」中的「去自我化」。"
    },
    {
      "id": "第01章 内化教练思维的真谛",
      "type": "chapter",
      "tagline": "教练为什么越想做得专业，越容易错过真正的现场。"
    },
    {
      "id": "第02章 校准你的神经系统",
      "type": "chapter",
      "tagline": "当教练自己身体发紧、脑子过热时，为什么很难创造突破。"
    },
    {
      "id": "第03章 选择你的情绪",
      "type": "chapter",
      "tagline": "教练在现场为什么总被紧张、焦躁和想控制的冲动带着走。"
    },
    {
      "id": "第04章 觉察与释放评判性反应",
      "type": "chapter",
      "tagline": "评判为什么会把临在和安全感悄悄抽走。"
    },
    {
      "id": "第05章 如何在寻求解决问题的同时以教练方式引导他人",
      "type": "chapter",
      "tagline": "面对客户想要“赶紧解决问题”的冲动，教练如何既不失去方向也不陷入解题。"
    },
    {
      "id": "第06章 如何倾听才能带来突破",
      "type": "chapter",
      "tagline": "为什么很多“听得很认真”的教练，仍然没有真正打开客户。"
    },
    {
      "id": "第07章 情绪表达反馈的价值",
      "type": "chapter",
      "tagline": "客户的情绪和身份感受，为什么常常比他们口头上的说法更接近真相。"
    },
    {
      "id": "第08章 如何在情绪时刻中引导出顿悟",
      "type": "chapter",
      "tagline": "客户一有情绪，教练为什么最容易在关键时刻把突破打断。"
    },
    {
      "id": "第09章 清晰且可观测目标成果的必要性",
      "type": "chapter",
      "tagline": "没有清晰目标时，为什么教练很容易停留在表层理解。"
    },
    {
      "id": "第10章 厘清实现目标过程中的障碍",
      "type": "chapter",
      "tagline": "当目标已经清楚，为什么人还是很难行动。"
    },
    {
      "id": "第11章 觉察思维演进过程中目标的转变",
      "type": "chapter",
      "tagline": "当客户的真正愿望在会谈中浮现时，教练怎么判断是跟还是拉回。"
    },
    {
      "id": "第12章 突破阻抗的教练对话",
      "type": "chapter",
      "tagline": "面对客户的抗拒，教练为什么常常比客户更先着急。"
    },
    {
      "id": "第13章 操作系统内部探秘",
      "type": "chapter",
      "tagline": "为什么人明知旧模式无效，却还是会回到老的自动驾驶。"
    },
    {
      "id": "第14章 社交需求的优势与陷阱",
      "type": "chapter",
      "tagline": "为什么越想被认可、被需要、被看重，有时越会卡住改变。"
    },
    {
      "id": "第15章 价值观契合的重要性",
      "type": "chapter",
      "tagline": "为什么很多计划看起来合理，却总是做不久。"
    },
    {
      "id": "第16章 巩固新认知以完成突破过程",
      "type": "chapter",
      "tagline": "为什么很多洞见刚出现时很亮，却很快又变模糊。"
    },
    {
      "id": "第17章 将洞见与承诺相结合",
      "type": "chapter",
      "tagline": "为什么客户明明看见了，临门一脚却还是容易退回去。"
    },
    {
      "id": "第18章 教练的价值衡量",
      "type": "chapter",
      "tagline": "教练效果为什么不能只靠“聊得很好”来衡量。"
    },
    {
      "id": "去自我化",
      "type": "concept",
      "tagline": "去自我化是教练不让自己的表现欲、判断和修理冲动抢走现场的能力。"
    },
    {
      "id": "神经系统校准",
      "type": "concept",
      "tagline": "神经系统校准是教练通过身体与呼吸把自己带回稳定、开放和能容纳复杂情绪的状态。"
    },
    {
      "id": "非反应式共情",
      "type": "concept",
      "tagline": "非反应式共情是在理解对方情绪的同时，不急着安抚、不急着修理。"
    },
    {
      "id": "可观测目标",
      "type": "concept",
      "tagline": "可观测目标是能被描述、被辨认、被检验的会谈结果图像。"
    },
    {
      "id": "操作系统",
      "type": "concept",
      "tagline": "操作系统是人用过去经验、身份认同和解释模式来处理现实的内部程序。"
    },
    {
      "id": "社交需求",
      "type": "concept",
      "tagline": "社交需求是人对归属、认同、尊重和位置感的深层需要。"
    },
    {
      "id": "价值观契合",
      "type": "concept",
      "tagline": "价值观契合是行动方向与内心真正看重之物之间的一致性。"
    },
    {
      "id": "洞见转承诺",
      "type": "concept",
      "tagline": "洞见转承诺是把顿悟时刻变成具体行动、时间点与责任感的过程。"
    },
    {
      "id": "全书主动作",
      "type": "method",
      "tagline": "当你希望一场会谈不只是顺畅，而是真的发生突破时。"
    },
    {
      "id": "用「第1-4章：先稳住教练自己」处理关键问题",
      "type": "method",
      "tagline": "当你发现自己想证明专业、急着修理客户或被客户情绪带跑时。"
    },
    {
      "id": "用「第5-8章：在现场创造突破」处理关键问题",
      "type": "method",
      "tagline": "当客户开始松动，却又想迅速回到安全叙事时。"
    },
    {
      "id": "用「第9-12章：守住目标并穿过阻抗」处理关键问题",
      "type": "method",
      "tagline": "当会谈一直在话题里绕圈，或者客户明明想改变却始终不动。"
    },
    {
      "id": "用「第13-18章：调试操作系统并收束承诺」处理关键问题",
      "type": "method",
      "tagline": "当客户知道道理却总是回到旧模式，或在临门一脚时退缩时。"
    },
    {
      "id": "Marcia Reynolds（玛西娅·雷诺兹）",
      "type": "person",
      "tagline": "《教练的突破》作者"
    }
  ],
