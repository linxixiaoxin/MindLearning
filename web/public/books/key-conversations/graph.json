      "id": "沉默与暴力",
      "type": "concept",
      "tagline": "人在不安全时最常见的两种失控反应。"
    },
    {
      "id": "安全感",
      "type": "concept",
      "tagline": "让对方愿意继续留在对话里的心理条件。"
    },
    {
      "id": "共同目的",
      "type": "concept",
      "tagline": "让双方都感觉这不是输赢之争。"
    },
    {
      "id": "相互尊重",
      "type": "concept",
      "tagline": "即使有分歧，也不让对方觉得自己被贬低。"
    },
    {
      "id": "从事实到故事",
      "type": "concept",
      "tagline": "人会根据事实自动编故事，再被故事推动情绪和行动。"
    },
    {
      "id": "STATE表达法",
      "type": "concept",
      "tagline": "分享事实、讲出故事、征询他见、试探表达、鼓励测试。"
    },
    {
      "id": "真正目标",
      "type": "method",
      "tagline": "从想赢、想罚、想逃退回到真正想解决什么。"
    },
    {
      "id": "傻瓜式选择",
      "type": "method",
      "tagline": "别把关键对话误读成只能顶住或躲开。"
    },
    {
      "id": "对比法",
      "type": "method",
      "tagline": "先澄清你不想表达什么，再说明你真正想要什么。"
    },
    {
      "id": "共同目的四步法",
      "type": "method",
      "tagline": "先挖出双方共同想保住的东西，再一起找第三条路。"
    },
    {
      "id": "AMPP倾听法",
      "type": "method",
      "tagline": "用询问、确认、复述、主动引导把人请回共享里。"
    },
    {
      "id": "赞同-补充-比较",
      "type": "method",
      "tagline": "听懂之后，继续把差异留在共享里，而不是马上回击。"
    },
    {
      "id": "决策四分法",
      "type": "method",
      "tagline": "把讨论和决定区分开，明确谁来决定以及怎么跟进。"
    },
    {
      "id": "模式问题",
      "type": "method",
      "tagline": "当同类冲突反复出现时，把讨论从事件层升级到模式层。"
    },
    {
      "id": "暂停后重启",
      "type": "method",
      "tagline": "不是拖延，而是先把节奏拉回可谈区再继续。"
    }
