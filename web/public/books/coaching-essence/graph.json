  "nodes": [
    {
      "id": "全书导读",
      "type": "topic",
      "tagline": "这本书要解决的不是怎样提出更漂亮的问题，而是如何用“回放式探究”让客户看见自己的思维、情绪和模式，从而自己长出洞见与承诺。"
    },
    {
      "id": "全书脉络",
      "type": "topic",
      "tagline": "按章节推进链快速拿到这本书的主线。"
    },
    {
      "id": "核心内容总览",
      "type": "topic",
      "tagline": "把主题、概念、方法和章节资产收成一张总表。"
    },
    {
      "id": "单章目录",
      "type": "topic",
      "tagline": "从章节切进去，顺着原书推进。"
    },
    {
      "id": "选题角度",
      "type": "topic",
      "tagline": "把书里的结构问题翻译成可直接做内容的切口。"
    },
    {
      "id": "视觉表达钩子",
      "type": "topic",
      "tagline": "提炼适合信息图、九图和封面表达的视觉对象。"
    },
    {
      "id": "教练的本质",
      "type": "topic",
      "tagline": "这本书要解决的不是怎样提出更漂亮的问题，而是如何用“回放式探究”让客户看见自己的思维、情绪和模式，从而自己长出洞见与承诺。"
    },
    {
      "id": "三大思维习惯：当下感、接收信息、释放评判",
      "type": "topic",
      "tagline": "表面看是「技术学了不少，状态却总掉线。」，但这一段真正想带读者回到「分：三大思维习惯」中的「当下感」。"
    },
    {
      "id": "情绪一变化，真正的突破才刚开始",
      "type": "topic",
      "tagline": "表面看是「客户有明显情绪波动时，你反而不敢继续。」，但这一段真正想带读者回到「分：三大思维习惯」中的「领悟与承诺」。"
    },
    {
      "id": "教练不是职业限定，而是一种日常对话方式",
      "type": "topic",
      "tagline": "读者容易把「想把教练式沟通用到团队和家庭里。」当成表面问题，但这本书真正要处理的是「回放式探究」与「教练人而非问题」之间的结构关系。"
    },
    {
      "id": "管理者最大的教练误区：一开口就替别人想答案",
      "type": "topic",
      "tagline": "读者容易把「对方还没理清楚，你已经开始给方案。」当成表面问题，但这本书真正要处理的是「教练人而非问题」与「释放评判」之间的结构关系。"
    },
    {
      "id": "第01章 是什么让教练工作如此有力",
      "type": "chapter",
      "tagline": "为什么人很难靠自己打断旧的思维模式和自动反应。"
    },
    {
      "id": "第02章 错误的教练信念",
      "type": "chapter",
      "tagline": "哪些看似专业的教练信念，其实会把现场带偏。"
    },
    {
      "id": "第03章 聚焦：教练人，而非问题",
      "type": "chapter",
      "tagline": "为什么一直盯着问题细节，会让谈话越来越窄。"
    },
    {
      "id": "第04章 主动回放：回放关键片段以供检查",
      "type": "chapter",
      "tagline": "如何不用“神奇问题”，也能让客户停下来重新看自己。"
    },
    {
      "id": "第05章 打开客户的思维：发现真正的需求",
      "type": "chapter",
      "tagline": "客户被旧故事困住时，怎么帮助他看见更深层的需求与限制。"
    },
    {
      "id": "第06章 守住目标：坚持到底",
      "type": "chapter",
      "tagline": "如果不把期望结果说清，谈话为什么总是又绕回原点。"
    },
    {
      "id": "第07章 创新与展望：教练领悟和承诺",
      "type": "chapter",
      "tagline": "为什么很多谈话有领悟、有感动，却没有真正改变。"
    },
    {
      "id": "第08章 调整大脑——培养你的当下感",
      "type": "chapter",
      "tagline": "教练为什么总在关键时刻被自己的紧张、杂念和表现欲带跑。"
    },
    {
      "id": "第09章 接收信息（不只是倾听）",
      "type": "chapter",
      "tagline": "只靠认知层面的倾听，为什么会漏掉最关键的信息。"
    },
    {
      "id": "第10章 觉察评判并将其释放",
      "type": "chapter",
      "tagline": "评判为什么会在不知不觉中破坏安全感和伙伴关系。"
    },
    {
      "id": "回放式探究",
      "type": "concept",
      "tagline": "回放式探究是把客户的话、情绪和矛盾客观还给客户，再用提问推动其自我反思。"
    },
    {
      "id": "教练人而非问题",
      "type": "concept",
      "tagline": "教练的重点不是替客户解决外部问题，而是帮助其看见自己如何制造、维持和解释问题。"
    },
    {
      "id": "主动回放",
      "type": "concept",
      "tagline": "主动回放是对客户关键措辞、情绪变化和矛盾片段的即时映照。"
    },
    {
      "id": "期望结果",
      "type": "concept",
      "tagline": "期望结果是教练谈话真正想推进到的状态或变化图像。"
    },
    {
      "id": "领悟与承诺",
      "type": "concept",
      "tagline": "领悟是客户看见新真相的时刻，承诺是把这个新真相变成下一步行动。"
    },
    {
      "id": "当下感",
      "type": "concept",
      "tagline": "当下感是教练把注意力放在客户和现场，而不是放在自己表现上的能力。"
    },
    {
      "id": "释放评判",
      "type": "concept",
      "tagline": "释放评判是指教练觉察自己的标签、解释和冲动，不让它们接管谈话。"
    },
    {
      "id": "全书主动作",
      "type": "method",
      "tagline": "当你发现自己正忍不住给建议，或一味追求漂亮问题时。"
    },
    {
      "id": "用「第1-2章：教练为何有效与哪些信念会带偏」处理关键问题",
      "type": "method",
      "tagline": "当教练关系一开始就发紧，或你发现自己在追求表现感时。"
    },
    {
      "id": "用「第3-5章：聚焦人、主动回放、打开思维」处理关键问题",
      "type": "method",
      "tagline": "当对方反复讲同一个故事，却始终绕不出来时。"
    },
    {
      "id": "用「第6-7章：守住目标与领悟承诺」处理关键问题",
      "type": "method",
      "tagline": "当谈话一直在打转，或者客户说“我知道了”却没有行动时。"
    },
    {
      "id": "用「第8-10章：当下感、接收信息、释放评判」处理关键问题",
      "type": "method",
      "tagline": "当你在谈话中开始紧张、想控制、想纠正对方时。"
    },
    {
      "id": "Marcia Reynolds（玛莎·雷诺兹）",
      "type": "person",
      "tagline": "《教练的本质》作者"
    }
  ],
