  "nodes": [
    {
      "id": "全书导读",
      "type": "topic",
      "tagline": "凯根把人的成长解释为“主体—客体关系”持续重组的过程：人之所以被困住，往往不是因为不努力，而是因为还被旧的意义结构包着。"
    },
    {
      "id": "全书脉络",
      "type": "topic",
      "tagline": "按章节推进链快速拿到这本书的主线。"
    },
    {
      "id": "核心内容总览",
      "type": "topic",
      "tagline": "把主题、概念、方法和章节资产收成一张总表。"
    },
    {
      "id": "单章目录",
      "type": "topic",
      "tagline": "从章节切进去，顺着原书推进。"
    },
    {
      "id": "选题角度",
      "type": "topic",
      "tagline": "把书里的结构问题翻译成可直接做内容的切口。"
    },
    {
      "id": "视觉表达钩子",
      "type": "topic",
      "tagline": "提炼适合信息图、九图和封面表达的视觉对象。"
    },
    {
      "id": "发展的自我：自我成长中的过程与问题",
      "type": "topic",
      "tagline": "凯根把人的成长解释为“主体—客体关系”持续重组的过程：人之所以被困住，往往不是因为不努力，而是因为还被旧的意义结构包着。"
    },
    {
      "id": "大学适应不良，很多时候不是脆弱，而是旧关系系统失效了",
      "type": "topic",
      "tagline": "表面上看是适应力差，实际上是一个主要靠关系确认自己的自我，被迫开始自己 authoring。"
    },
    {
      "id": "所谓“反社会少年”，可能只是被错过了成长桥梁",
      "type": "topic",
      "tagline": "问题不只在行为本身，而在环境要求的成熟度超前于个体当前的意义结构。"
    },
    {
      "id": "成年人也会继续长大：自主并不是发展的终点",
      "type": "topic",
      "tagline": "我们总把独立当成熟终点，但凯根指出，独立本身也会变成新的牢笼。"
    },
    {
      "id": "治疗为什么常常输给环境：真正基础的是自然疗法",
      "type": "topic",
      "tagline": "我们总把专业治疗当主战场，却忽略了家庭、学校、工作和亲密关系才是更基础的成长土壤。"
    },
    {
      "id": "第01章 未被认识的让·皮亚杰的才华",
      "type": "chapter",
      "tagline": "为什么人的发展不能只理解为知识增加，而要理解为主体—客体关系的重组。"
    },
    {
      "id": "第02章 道德意义建构的演化",
      "type": "chapter",
      "tagline": "儿童如何从只看结果和利益，发展到能够真正理解他人立场与关系后果。"
    },
    {
      "id": "第03章 自我的结构",
      "type": "chapter",
      "tagline": "如何用同一套结构理解不同年龄段的自我、认知、情感和人际关系。"
    },
    {
      "id": "第04章 一体化自我的消长",
      "type": "chapter",
      "tagline": "婴儿为何必须先在被抱持、被确认的环境里，才能逐步把自己和世界区分开。"
    },
    {
      "id": "第05章 冲动性自我的消失",
      "type": "chapter",
      "tagline": "为什么5至7岁的孩子会从充满幻想和外显冲动，转向更能控制自己、更在意角色和规则的状态。"
    },
    {
      "id": "第06章 唯我性自我的消长",
      "type": "chapter",
      "tagline": "为什么特里、理查德这类被贴上“反社会”或“不能受雇”标签的人，其实常卡在唯我性平衡向人际性平衡的过渡里。"
    },
    {
      "id": "第07章 人际性自我的消长",
      "type": "chapter",
      "tagline": "为何恋家、被遗弃感和大学适应困难，常是人际性自我向法规性自我转变的信号。"
    },
    {
      "id": "第08章 法规性自我的消长",
      "type": "chapter",
      "tagline": "当一个人已经能自我 authoring，为何仍会因亲密关系、价值冲突或形式主义的崩塌而陷入危机。"
    },
    {
      "id": "第09章 自然疗法",
      "type": "chapter",
      "tagline": "真正推动人成长的支持，为什么往往先存在于日常关系和环境里，而不只在专业治疗里。"
    },
    {
      "id": "主体—客体关系",
      "type": "concept",
      "tagline": "一个人在某个阶段把什么直接当成“我”，又把什么当成可以被看见、被协调的对象，这组关系就是他的主体—客体关系。"
    },
    {
      "id": "演化停滞",
      "type": "concept",
      "tagline": "人在一段时期里形成的相对稳定平衡，它能让人活得顺手，但也会把人困在某种固定的意义组织里。"
    },
    {
      "id": "植入的文化",
      "type": "concept",
      "tagline": "个体当前沉浸其中、又借此维持自我的心理社会环境，例如抚育者、家庭、学校、同伴、工作和亲密关系。"
    },
    {
      "id": "抱持性环境",
      "type": "concept",
      "tagline": "温尼科特意义上的支持环境：它既能承接个体当下的存在，又能在适当时机让个体从这种承接里分化出来。"
    },
    {
      "id": "确认—矛盾—连续性",
      "type": "concept",
      "tagline": "支持环境的三项关键功能：先确认当下自我，再提供与旧平衡不完全一致的矛盾，同时保住关系连续性，避免成长被体验成抛弃。"
    },
    {
      "id": "分化与再整合",
      "type": "concept",
      "tagline": "发展不是线性加法，而是旧的主观性从中心退下，成为新自我可以协调的对象，然后再被纳入更复杂的整体。"
    },
    {
      "id": "冲动性自我",
      "type": "concept",
      "tagline": "在这一阶段，人开始摆脱最早期的一体化状态，但仍深度沉浸于自己的知觉和冲动，难以把它们当作对象处理。"
    },
    {
      "id": "唯我性自我",
      "type": "concept",
      "tagline": "人在这一阶段已经能组织需要、利益和意图，但主要仍从自己的需要观出发去理解世界与他人。"
    },
    {
      "id": "人际性自我",
      "type": "concept",
      "tagline": "人在这一阶段深度把关系、认可和他人期望纳入自我，容易通过“我们”的感觉来定义自己是谁。"
    },
    {
      "id": "法规性自我",
      "type": "concept",
      "tagline": "人在这一阶段能够以更稳定的规则、原则、目标和同一性来组织生活，不再完全受关系推动。"
    },
    {
      "id": "个人间自我",
      "type": "concept",
      "tagline": "人在更高阶段开始把自己的原则、身份和系统也看成对象，能够在关系与系统之间保持真正的相互依存与辩证思维。"
    },
    {
      "id": "自然疗法",
      "type": "concept",
      "tagline": "家庭、学校、工作与亲密关系等自然环境，在不自觉中为个体的成长和过渡提供支持、矛盾与连续性。"
    },
    {
      "id": "先判断一个人当前把什么当成“我”",
      "type": "method",
      "tagline": "适合在咨询、教育、管理或自我反思中判断一个人目前的意义结构。"
    },
    {
      "id": "用“确认—矛盾—连续性”检查支持环境",
      "type": "method",
      "tagline": "适合分析家庭养育、学校过渡、团队管理、咨询关系和亲密关系中的支持质量。"
    },
    {
      "id": "把症状翻译成发展危机",
      "type": "method",
      "tagline": "适合面对反社会行为、抑郁、恋家、空心感、职业适应不良等复杂表现时使用。"
    },
    {
      "id": "为过渡搭桥，而不是替对方活",
      "type": "method",
      "tagline": "适合陪伴从人际性自我走向法规性自我的青年，也适合支持成人面对身份重组。"
    },
    {
      "id": "用案例回看自己的成长位置",
      "type": "method",
      "tagline": "适合读完整本书后做个人复盘，也适合带着团队或来访者一起反思。"
    },
    {
      "id": "罗伯特·凯根",
      "type": "person",
      "tagline": "《发展的自我：自我成长中的过程与问题》作者"
    }
  ],
